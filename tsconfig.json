{
    "compilerOptions": {
        "target": "es2017",
        "moduleResolution": "Node",
        "ignoreDeprecations": "6.0", 
        "outDir": "dist/",
        "baseUrl": "./",
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "types": ["screeps", "node"],
        "strictNullChecks": false,
        "noImplicitAny": false,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "src/**/*.ts"
    ]
}